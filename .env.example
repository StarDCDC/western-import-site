# Environment Variables for Western Import Site

# Database (PostgreSQL on Render, SQLite for local dev)
DATABASE_URL="postgresql://user:password@localhost:5432/western_import"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Site
NEXT_PUBLIC_SITE_NAME="Western Import"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional integrations
# NINE_NINE_MD_API_KEY=""
# IUTE_CREDIT_API_KEY=""
